<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#40E8C85C" />
            <corners android:radius="@dimen/card_radius" />
        </shape>
    </item>
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/dasha_highlight_fill" />
            <corners android:radius="@dimen/card_radius" />
            <stroke
                android:width="2.5dp"
                android:color="@color/golden" />
        </shape>
    </item>
</layer-list>
