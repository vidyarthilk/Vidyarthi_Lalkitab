<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/card_shadow" />
            <corners
                android:topLeftRadius="@dimen/bottom_nav_radius"
                android:topRightRadius="@dimen/bottom_nav_radius" />
        </shape>
    </item>
    <item android:top="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/cream_white" />
            <stroke
                android:width="1dp"
                android:color="@color/golden" />
            <corners
                android:topLeftRadius="@dimen/bottom_nav_radius"
                android:topRightRadius="@dimen/bottom_nav_radius" />
        </shape>
    </item>
</layer-list>
