<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/deep_maroon"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="10dp"
    android:paddingVertical="8dp">

    <TextView
        android:id="@+id/tvColGraha"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.1"
        android:text="@string/graha_table_col_graha"
        android:textColor="@color/cream_white"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvColRashi"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.1"
        android:text="@string/graha_table_col_rashi"
        android:textColor="@color/cream_white"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvColDegree"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.8"
        android:gravity="end"
        android:text="@string/graha_table_col_degree"
        android:textColor="@color/cream_white"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>
