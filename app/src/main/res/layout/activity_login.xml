<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/loginToolbar"
            style="@style/Widget.Vidyarthi.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:title="@string/auth_title" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Vidyarthi.PremiumCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvLoginHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auth_register_hint"
                    android:textAppearance="@style/TextAppearance.Vidyarthi.Muted" />

                <TextView
                    android:id="@+id/tvLoginEmailLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:labelFor="@id/etLoginEmail"
                    android:text="@string/auth_email_label"
                    android:textAppearance="@style/TextAppearance.Vidyarthi.FormFieldLabel" />

                <EditText
                    android:id="@+id/etLoginEmail"
                    style="@style/Widget.Vidyarthi.EditField"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:hint="@string/auth_email_hint"
                    android:inputType="textEmailAddress"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/tvLoginPasswordLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:labelFor="@id/etLoginPassword"
                    android:text="@string/auth_password_label"
                    android:textAppearance="@style/TextAppearance.Vidyarthi.FormFieldLabel" />

                <EditText
                    android:id="@+id/etLoginPassword"
                    style="@style/Widget.Vidyarthi.EditField"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:hint="@string/auth_password_hint"
                    android:inputType="textPassword"
                    android:maxLines="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    style="@style/Widget.Vidyarthi.PrimaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/auth_btn_login" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegister"
                    style="@style/Widget.Vidyarthi.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/auth_btn_register" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
