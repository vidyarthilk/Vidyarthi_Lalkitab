<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_raja_vajir_dhoka_screen"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="ifContentScrolls">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_raja_screen_header"
            android:elevation="3dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingVertical="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/kalam_bold"
                android:letterSpacing="0.03"
                android:text="@string/raja_vajir_title"
                android:textColor="@color/blood_red"
                android:textSize="26sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/kalam_regular"
                android:text="@string/raja_vajir_subtitle"
                android:textColor="@color/orange_main"
                android:textSize="14sp" />

            <View
                android:layout_width="80dp"
                android:layout_height="2dp"
                android:layout_marginTop="10dp"
                android:background="#D4A017" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#D9FFF8F0"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp"
            app:strokeColor="#D4A017"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp">

                <androidx.appcompat.widget.AppCompatSpinner
                    android:id="@+id/spinnerVarshfalYear"
                    style="@style/Widget.Vidyarthi.Spinner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:dropDownHeight="@dimen/spinner_dropdown_compact_height"
                    android:minHeight="40dp"
                    android:popupBackground="@drawable/bg_year_spinner_dropdown" />

                <TextView
                    android:id="@+id/tvVarshfalYearInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/kalam_regular"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp"
                    android:paddingHorizontal="4dp"
                    android:textColor="@color/blood_red"
                    android:textSize="13sp"
                    tools:text="Year 45 (01/01/2020 - 01/01/2021) · current varshfal" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:text="@string/mukhya_janma_hero_section"
            android:textAppearance="@style/TextAppearance.Vidyarthi.SectionHeader" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:weightSum="3">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_spiritual_card_raja"
                android:elevation="5dp"
                android:gravity="center_horizontal"
                android:minHeight="@dimen/triad_card_min_height"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="16dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_triad_crown" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/kalam_bold"
                    android:gravity="center"
                    android:text="@string/mukhya_raja_label"
                    android:textColor="@color/orange_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvHeroRaja"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/kalam_bold"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/blood_red"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="શનિ\nખાનું 5" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_spiritual_card_vazir"
                android:elevation="4dp"
                android:gravity="center_horizontal"
                android:minHeight="@dimen/triad_card_min_height"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="16dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_triad_advisor" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/kalam_bold"
                    android:gravity="center"
                    android:text="@string/mukhya_vazir_label"
                    android:textColor="@color/orange_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvHeroVazir"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/kalam_bold"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/blood_red"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="ગુરુ·બુધ\nખાનું 3" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_spiritual_card_dhoka"
                android:elevation="3.5dp"
                android:gravity="center_horizontal"
                android:minHeight="@dimen/triad_card_min_height"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="16dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_triad_warning" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/kalam_bold"
                    android:gravity="center"
                    android:text="@string/mukhya_dhoka_label"
                    android:textColor="@color/orange_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvHeroDhoka"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/kalam_bold"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/blood_red"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="રાહુ\nખાનું 12" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:text="@string/mukhya_chandra_hero_section"
            android:textAppearance="@style/TextAppearance.Vidyarthi.SectionHeader" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:weightSum="3">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_spiritual_card_raja"
                android:elevation="5dp"
                android:gravity="center_horizontal"
                android:minHeight="@dimen/triad_card_min_height"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="16dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_triad_crown" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/kalam_bold"
                    android:gravity="center"
                    android:text="@string/mukhya_raja_label"
                    android:textColor="@color/orange_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvHeroRajaChandra"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/kalam_bold"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/blood_red"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="રાહુ\nખાનું 11" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_spiritual_card_vazir"
                android:elevation="4dp"
                android:gravity="center_horizontal"
                android:minHeight="@dimen/triad_card_min_height"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="16dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_triad_advisor" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/kalam_bold"
                    android:gravity="center"
                    android:text="@string/mukhya_vazir_label"
                    android:textColor="@color/orange_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvHeroVazirChandra"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/kalam_bold"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/blood_red"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="રાહુ\nખાનું 11" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_spiritual_card_dhoka"
                android:elevation="3.5dp"
                android:gravity="center_horizontal"
                android:minHeight="@dimen/triad_card_min_height"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="16dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_triad_warning" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/kalam_bold"
                    android:gravity="center"
                    android:text="@string/mukhya_dhoka_label"
                    android:textColor="@color/orange_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvHeroDhokaChandra"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/kalam_bold"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/blood_red"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="રાહુ\nખાનું 11" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
