<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:descendantFocusability="afterDescendants"
    android:orientation="horizontal"
    android:paddingBottom="4dp">

    <LinearLayout
        android:layout_width="32dp"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <View
            android:id="@+id/timelineLineTop"
            android:layout_width="2dp"
            android:layout_height="12dp"
            android:background="#66E8C85C" />

        <View
            android:id="@+id/timelineDot"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="@drawable/bg_timeline_dot" />

        <View
            android:id="@+id/timelineLineBottom"
            android:layout_width="2dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#66E8C85C"
            android:minHeight="20dp" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDasha"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="12dp"
        android:layout_weight="1"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="@dimen/card_radius"
        app:cardElevation="@dimen/card_elevation"
        app:rippleColor="#40E8C85C"
        app:strokeColor="@color/golden"
        app:strokeWidth="2dp">

        <LinearLayout
            android:id="@+id/cardDashaInner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_dasha_timeline_card"
            android:orientation="horizontal">

            <View
                android:id="@+id/accentBarCurrent"
                android:layout_width="5dp"
                android:layout_height="match_parent"
                android:background="@color/golden"
                android:visibility="gone"
                tools:visibility="visible" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingHorizontal="14dp"
                android:paddingVertical="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textMahadasha"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="false"
                        android:focusable="false"
                        android:paddingVertical="2dp"
                        android:textAppearance="@style/TextAppearance.Vidyarthi.DashaMaha"
                        tools:text="રાહુ" />

                    <TextView
                        android:id="@+id/textCurrentBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_dasha_current_badge"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="@string/dasha_current_label"
                        android:textAppearance="@style/TextAppearance.Vidyarthi.AccentTag"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <TextView
                        android:id="@+id/textAge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_dasha_age_chip"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:textAppearance="@style/TextAppearance.Vidyarthi.CaptionBold"
                        tools:text="ઉંમર: 42" />
                </LinearLayout>

                <TextView
                    android:id="@+id/textStartDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textAppearance="@style/TextAppearance.Vidyarthi.DashaMeta"
                    tools:text="01/01/2020 - 01/01/2026" />

                <TextView
                    android:id="@+id/textEndDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
