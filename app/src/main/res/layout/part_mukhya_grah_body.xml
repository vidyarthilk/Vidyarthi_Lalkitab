<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tvYearHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/kalam_bold"
        android:textColor="@color/blood_red"
        android:textSize="16sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="@font/kalam_regular"
        android:text="@string/mukhya_grah_year_label"
        android:textColor="@color/blood_red"
        android:textSize="14sp" />

    <androidx.appcompat.widget.AppCompatSpinner
        android:id="@+id/yearSpinner"
        style="@style/Widget.Vidyarthi.Spinner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:dropDownHeight="@dimen/spinner_dropdown_compact_height"
        android:minHeight="48dp"
        android:popupBackground="@drawable/bg_year_spinner_dropdown" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/orange_main"
        app:strokeWidth="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/kalam_bold"
                android:text="@string/mukhya_card_janma_title"
                android:textColor="@color/blood_red"
                android:textSize="17sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/kalam_bold"
                android:text="@string/mukhya_grahfal_raja_caption"
                android:textColor="@color/blood_red"
                android:textStyle="bold"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tvJanmaRaja"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/kalam_bold"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/blood_red"
                android:textSize="20sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/kalam_bold"
                android:text="@string/mukhya_rashifal_vazir_caption"
                android:textColor="@color/blood_red"
                android:textStyle="bold"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tvJanmaVazir"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/kalam_bold"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/blood_red"
                android:textSize="20sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/kalam_bold"
                android:text="@string/mukhya_dhoka_caption"
                android:textColor="@color/blood_red"
                android:textStyle="bold"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tvJanmaDhoka"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/kalam_bold"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/blood_red"
                android:textSize="20sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/orange_main"
        app:strokeWidth="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/kalam_bold"
                android:text="@string/mukhya_card_chandra_title"
                android:textColor="@color/blood_red"
                android:textSize="17sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/kalam_bold"
                android:text="@string/mukhya_grahfal_raja_caption"
                android:textColor="@color/blood_red"
                android:textStyle="bold"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tvChandraRaja"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/kalam_bold"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/blood_red"
                android:textSize="20sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/kalam_bold"
                android:text="@string/mukhya_rashifal_vazir_caption"
                android:textColor="@color/blood_red"
                android:textStyle="bold"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tvChandraVazir"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/kalam_bold"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/blood_red"
                android:textSize="20sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/kalam_bold"
                android:text="@string/mukhya_dhoka_caption"
                android:textColor="@color/blood_red"
                android:textStyle="bold"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tvChandraDhoka"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/kalam_bold"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/blood_red"
                android:textSize="20sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
