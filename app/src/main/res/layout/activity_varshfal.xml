<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="false"
    android:overScrollMode="ifContentScrolls">

    <LinearLayout
        android:id="@+id/varshfalRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.appcompat.widget.AppCompatSpinner
            android:id="@+id/yearSpinner"
            style="@style/Widget.Vidyarthi.Spinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:dropDownHeight="@dimen/spinner_dropdown_compact_height"
            android:popupBackground="@drawable/bg_year_spinner_dropdown" />

        <TextView
            android:id="@+id/tvYearInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Vidyarthi.Accent"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/varshfal_janma_title"
            android:textAppearance="@style/TextAppearance.Vidyarthi.SectionTitle"
            android:textSize="22sp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent">

            <com.vidyarthi.lalkitab.ui.kundli.KundliChartView
                android:id="@+id/janmaVarshfalChart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/kundli_chart_min_size" />

        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvBudhSvabhavJanmaVarshfal"
            style="@style/TextAppearance.Vidyarthi.BudhSvabhav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
