<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ================================================= -->
    <!-- REQUIRED BASE SHAPE (Material3 needs this) -->
    <!-- ================================================= -->
    <style name="Shape">
        <item name="cornerFamily">rounded</item>
    </style>

    <style name="Shape.Square">
        <item name="cornerFamily">cut</item>
        <item name="cornerSize">0dp</item>
    </style>

    <!-- ================================================= -->
    <!-- TEXT APPEARANCE : BLOOD RED + KALAM FONT -->
    <!-- ================================================= -->

    <!-- App Main Heading -->
    <style name="TextAppearance.Vidyarthi.Heading"
        parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/kalam_family</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">26sp</item>
        <item name="android:textColor">@color/blood_red</item>
    </style>

    <!-- Section Heading -->
    <style name="TextAppearance.Vidyarthi.SubHeading"
        parent="TextAppearance.Material3.TitleMedium">
        <item name="fontFamily">@font/kalam_family</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/blood_red</item>
    </style>

    <!-- Normal Body Text -->
    <style name="TextAppearance.Vidyarthi.Body"
        parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/kalam_family</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/blood_red</item>
    </style>

    <!-- Small Text -->
    <style name="TextAppearance.Vidyarthi.Small"
        parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">@font/kalam_family</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/blood_red</item>
    </style>
    <style name="TabTextStyle">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/blood_red</item>
        <item name="android:textStyle">bold</item>
    </style>
    <!-- ================================================= -->
    <!-- SQUARE ORANGE BUTTON -->
    <!-- ================================================= -->
    <style name="SquareButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">0dp</item>
        <item name="backgroundTint">@color/orange_main</item>
        <item name="android:textColor">@color/blood_red</item>
    </style>

</resources>
